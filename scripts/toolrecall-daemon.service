[Unit]
Description=ToolRecall Daemon — Tool-Output Cache + MCP Multiplexer
After=network.target

[Service]
Type=simple
ExecStart=%h/.toolrecall/venv/bin/toolrecall daemon --foreground
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Hardening
PrivateTmp=true
NoNewPrivileges=true
ProtectHome=soft
ProtectSystem=full

[Install]
WantedBy=multi-user.target
